POSTGRES_DB=cara_de_abelha
POSTGRES_USER=bee
POSTGRES_PASSWORD=bee

SERVER_PORT=8080
SERVER_READ_TIMEOUT_SECONDS=10
SERVER_WRITE_TIMEOUT_SECONDS=10
SERVER_IDLE_TIMEOUT_SECONDS=60
SERVER_SHUTDOWN_TIMEOUT_SECONDS=10

# Para o server rodando dentro do Docker Compose, o hostname do banco e `db`.
DATABASE_URL=postgres://bee:bee@db:5432/cara_de_abelha?sslmode=disable

# Troque pelo IP local da maquina que esta rodando o Docker quando for testar em outro computador.
# Exemplo: 192.168.0.25
LAN_HOST=192.168.0.25

VITE_API_URL=http://${LAN_HOST}:8080
VITE_WS_URL=ws://${LAN_HOST}:8080/ws